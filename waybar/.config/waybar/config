{
    "layer": "top",
    "position": "top",
    "height": 30,
    "modules-left": ["niri/workspaces", "keyboard-state"],
    "modules-center": ["clock"],
    "modules-right": ["cpu", "memory", "pulseaudio", "tray"],

    "keyboard-state": {
        "numlock": false,
        "capslock": false,
        "format": "{name}",
        "format-icons": {
            "locked": "",
            "unlocked": ""
        }
    },

    "clock": {
        "format": "{:%a %d %b  %H:%M}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "cpu": {
        "format": " {usage}%",
        "interval": 2
    },

    "memory": {
        "format": " {used:0.1f}G",
        "interval": 5
    },

    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-muted": " ",
        "format-icons": {
            "default": ["", "", ""]
        }
    },

    "tray": {
        "spacing": 10
    }
}
